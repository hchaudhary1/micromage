# Keep local OS metadata out of source history.
.DS_Store
Thumbs.db

# Ignore editor and local environment files that are unique to each contributor.
.idea/
.vscode/
*.swp
*.swo
.env
.env.*

# Keep Go build, test, and coverage outputs from mixing with source changes.
/bin/
/dist/
/tmp/
*.test
coverage.out
coverage.*

# Ignore the default binary name if someone runs `go build ./cmd/server` locally.
/server
