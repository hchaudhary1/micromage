#!/bin/sh
set -eu

minimum_coverage="70.0"
coverage_file="$(mktemp -t micromage-coverage.XXXXXX)"
trap 'rm -f "$coverage_file"' EXIT

blocked_reference="$(printf '\101\162\143\150\157\156')"

echo "Checking blocked reference terms..."
# Keep source language independent from comparison projects before it enters history.
blocked_matches="$(git grep --cached -I -n -i -- "$blocked_reference" -- . || true)"
if [ -n "$blocked_matches" ]; then
  echo "Blocked reference term found in staged content:" >&2
  echo "$blocked_matches" >&2
  exit 1
fi

echo "Running Go tests with coverage..."
go test ./... -coverprofile="$coverage_file"

total_coverage="$(go tool cover -func="$coverage_file" | awk '/^total:/ { sub(/%/, "", $3); print $3 }')"

if [ -z "$total_coverage" ]; then
  echo "Could not determine total coverage." >&2
  exit 1
fi

# Coverage gate protects feature quality before changes enter history.
awk -v total="$total_coverage" -v minimum="$minimum_coverage" '
  BEGIN {
    if (total + 0 < minimum + 0) {
      printf "Coverage %.1f%% is below the required %.1f%%.\n", total, minimum > "/dev/stderr"
      exit 1
    }
    printf "Coverage %.1f%% meets the required %.1f%%.\n", total, minimum
  }
'
